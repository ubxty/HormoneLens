        <span class="float-tag" style="top:68%;left:5%;   --tf-delay:4.8s;">💉 Insulin Sensitivity</span>
        <span class="float-tag" style="top:78%;right:6%;  --tf-delay:6s;">📊 Glucose Response</span>
    </div>

    {{-- ═══ RIGHT PANEL ═══ --}}
