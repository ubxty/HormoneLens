                           class="w-4 h-4 rounded border-gray-300 text-violet-600 focus:ring-violet-500">
                    <label for="remember" class="text-sm text-gray-500">Remember me</label>
                </div>
                <button type="submit" class="hl-btn">
                    Sign In to Simulation Lab
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-500">
                Don't have an account?
                <a href="{{ route('register') }}" class="font-semibold text-violet-600 hover:text-violet-700 transition-colors">
                    Create Simulation Profile
                </a>
            </p>
        </div>
    </div>

</div>

<script>
(function () {
    var panel = document.querySelector('.left-panel');
    var arm   = document.getElementById('bfig-rarm');
    function triggerWave() {
        if (!arm) return;
        arm.classList.remove('waving');
        void arm.offsetWidth;
        arm.classList.add('waving');
        arm.addEventListener('animationend', function done() {
            arm.classList.remove('waving');
            arm.removeEventListener('animationend', done);
        });
    }
    if (panel) {
        panel.addEventListener('click', triggerWave);
        panel.addEventListener('mouseenter', triggerWave);
    }
})();
</script>
</body>
</html>
